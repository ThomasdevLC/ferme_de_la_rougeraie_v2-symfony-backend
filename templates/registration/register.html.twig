{% extends 'base.html.twig' %}

{% block title %}Créer un compte{% endblock %}

{% block body %}
    <style>
        .register-page {
            --base: #e6d2be;
            --bg-blend: multiply;
            --blur: 0px;
            --fg-blend: soft-light;
            --foreground: #ff8000;
            --opacity: 0.54;
            --spacing: 0px;
            min-height: 100vh;
            position: relative;
        }

        .register-background {
            background-color: var(--base);
            bottom: 0;
            display: flex;
            left: 0;
            overflow: hidden;
            padding: var(--spacing);
            position: fixed;
            right: 0;
            top: 0;
            width: 100vw;
            height: 100vh;
            z-index: -1;
        }

        .register-background img {
            bottom: 0;
            height: 100%;
            left: 0;
            object-fit: cover;
            position: absolute;
            right: 0;
            top: 0;
            width: 100%;
        }

        .register-bg-photo {
            filter: grayscale(100%) contrast(1) blur(var(--blur));
            mix-blend-mode: var(--bg-blend);
            opacity: var(--opacity);
            z-index: 0;
        }

        .register-bg-texture {
            mix-blend-mode: multiply;
            opacity: 0.28;
            z-index: 1;
        }

        .register-background::before {
            background-color: var(--foreground);
            bottom: 0;
            content: '';
            left: 0;
            mix-blend-mode: var(--fg-blend);
            position: absolute;
            right: 0;
            top: 0;
            z-index: 2;
        }

        .register-page .container {
            position: relative;
            z-index: 0;
        }

        .register-card .form-label,
        .register-card .form-check-label {
            font-size: 0.85rem;
        }

        .return-shop-link {
            color: #6c757d;
            font-size: 0.85rem;
            text-decoration: none;
        }

        .return-shop-link:hover {
            color: #6c757d;
            text-decoration: underline;
        }

        .register-card .invalid-feedback,
        .register-card .form-error-message {
            display: block;
            color: #dc3545;
            font-size: 0.75rem;
            margin-top: 0.25rem;
        }

        .register-card .form-error-icon {
            display: none;
        }
    </style>

    <div class="register-page">
        <div class="register-background" aria-hidden="true">
            <img class="register-bg-photo" src="{{ asset('images/register-background.jpg') }}" alt="">
            <img class="register-bg-texture" src="{{ asset('images/background.png') }}" alt="">
        </div>

        <div class="container min-vh-100 d-flex align-items-center justify-content-center">
            <div class="register-card" style="max-width: 500px; width: 100%; background: rgba(255, 255, 255, 0.85); border: 1px solid #c4c4c4; border-radius: 2px; padding: 1.5rem;">

            <div class="text-center mb-3">
                <img src="{{ asset('images/logo.png') }}" alt="Logo" style="height: 100px;">
            </div>

            <h5 class="text-center mb-3">Création compte</h5>

            {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}
            {{ form_errors(registrationForm) }}

            <div class="mb-3">
                {{ form_label(registrationForm.firstName, 'Prénom', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(registrationForm.firstName, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(registrationForm.firstName) }}
            </div>

            <div class="mb-3">
                {{ form_label(registrationForm.lastName, 'Nom', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(registrationForm.lastName, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(registrationForm.lastName) }}
            </div>

            <div class="mb-3">
                {{ form_label(registrationForm.email, 'Adresse email', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(registrationForm.email) }}
            </div>

            <div class="mb-3">
                {{ form_label(registrationForm.phone, 'Téléphone', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(registrationForm.phone, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(registrationForm.phone) }}
            </div>

            <div class="mb-3">
                <label class="form-label">Mot de passe</label>
                <div class="input-group">
                    {{ form_widget(registrationForm.plainPassword, {
                        'attr': {
                            'class': 'form-control password-input'
                        }
                    }) }}
                    <button type="button" class="btn btn-outline-secondary" onclick="togglePassword(this)">
          <span class="icon-eye">

            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 class="lucide lucide-eye">
              <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
          </span>
                    </button>
                </div>
                {{ form_errors(registrationForm.plainPassword) }}
            </div>

            <div class="mb-3">
                <div class="d-flex align-items-start gap-2">
                    {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input mt-1'}}) }}
                    <label class="form-check-label">
                        J'accepte les
                        <a href="#" data-bs-toggle="modal" data-bs-target="#modalCgu" class="text-decoration-underline" style="color: #fe8401;">conditions générales</a>
                        et la
                        <a href="#" data-bs-toggle="modal" data-bs-target="#modalConfidentialite" class="text-decoration-underline" style="color: #fe8401;">politique de confidentialité</a>
                    </label>
                </div>
                {{ form_errors(registrationForm.agreeTerms) }}
            </div>

            <div class="d-grid mb-3">
                <button type="submit" class="btn text-white" style="background-color: #fe8401;">
                    S'inscrire
                </button>
            </div>

            {{ form_end(registrationForm) }}

            <div class="text-center mt-4">
                <a href="{{ frontUrl }}/products" class="return-shop-link">Retour à la boutique →</a>
            </div>
            </div>
        </div>
    </div>

    {# Modale CGU #}
    <div class="modal fade" id="modalCgu" tabindex="-1" aria-labelledby="modalCguLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable">
            <div class="modal-content" style="border-radius: 2px; font-family: 'Roboto Mono', monospace;">
                <div class="modal-header" style="border-bottom: 1px solid #c4c4c4;">
                    <h6 class="modal-title" id="modalCguLabel">Conditions générales d'utilisation</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body" style="font-size: 0.85rem;">
                    <p>La liste des légumes disponibles avec leur prix est mise à jour chaque début de semaine.</p>
                    <p>Vous avez jusqu'à 21h la veille du jour de vente pour passer une pré-commande.</p>
                    <p>Le montant est indicatif et peut légèrement être ajusté à la réalité du poids des légumes.</p>
                    <p>Le règlement se fait à la réception, les jours de vente où il est possible de modifier ou de compléter sa commande.</p>
                    <hr style="border-color: #c4c4c4;">
                    <p class="mb-1"><strong>Ferme de la Rougeraie</strong></p>
                    <p class="mb-1">La Rougeraie, 56120 Forges de Lanouée</p>
                    <p class="mb-1"><a href="tel:0683341370">06 83 34 13 70</a></p>
                    <p class="mb-0"><a href="mailto:fermedelarougeraie@gmail.com">fermedelarougeraie@gmail.com</a></p>
                </div>
                <div class="modal-footer" style="border-top: 1px solid #c4c4c4;">
                    <button type="button" class="btn btn-sm text-white border-0 rounded-0" style="background-color: #fe8401;" data-bs-dismiss="modal">Fermer</button>
                </div>
            </div>
        </div>
    </div>

    {# Modale Confidentialité #}
    <div class="modal fade" id="modalConfidentialite" tabindex="-1" aria-labelledby="modalConfidentialiteLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable">
            <div class="modal-content" style="border-radius: 2px; font-family: 'Roboto Mono', monospace;">
                <div class="modal-header" style="border-bottom: 1px solid #c4c4c4;">
                    <h6 class="modal-title" id="modalConfidentialiteLabel">Politique de confidentialité</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body" style="font-size: 0.85rem;">
                    <p><strong>Dernière mise à jour : {{ "now"|date("d/m/Y") }}</strong></p>

                    <p><strong>1. Responsable du traitement</strong><br>
                    Ferme de la Rougeraie — La Rougeraie, 56120 Forges de Lanouée<br>
                    fermedelarougeraie@gmail.com</p>

                    <p><strong>2. Données collectées</strong><br>
                    Lors de votre inscription, nous collectons : prénom, nom, adresse email, numéro de téléphone. Ces données sont nécessaires à la gestion de vos commandes.</p>

                    <p><strong>3. Finalités</strong><br>
                    Vos données sont utilisées pour : gérer votre compte et vos commandes, vous informer de l'état de vos commandes, vous contacter en cas de besoin.</p>

                    <p><strong>4. Durée de conservation</strong><br>
                    Vos données sont conservées pendant la durée de votre relation avec la Ferme de la Rougeraie, puis archivées 3 ans conformément aux obligations légales.</p>

                    <p><strong>5. Vos droits</strong><br>
                    Conformément au RGPD, vous disposez d'un droit d'accès, de rectification, d'effacement et de portabilité de vos données. Pour exercer ces droits : <a href="mailto:fermedelarougeraie@gmail.com">fermedelarougeraie@gmail.com</a></p>

                    <p><strong>6. Partage des données</strong><br>
                    Vos données ne sont jamais vendues ni transmises à des tiers à des fins commerciales.</p>

                    <p><strong>7. Réclamation</strong><br>
                    Vous pouvez introduire une réclamation auprès de la CNIL (<a href="https://www.cnil.fr" target="_blank">www.cnil.fr</a>).</p>
                </div>
                <div class="modal-footer" style="border-top: 1px solid #c4c4c4;">
                    <button type="button" class="btn btn-sm text-white border-0 rounded-0" style="background-color: #fe8401;" data-bs-dismiss="modal">Fermer</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function togglePassword(btn) {
            const input = btn.closest('.input-group').querySelector('input.password-input');
            const icon = btn.querySelector('span.icon-eye');
            if (!input) return;

            // œil fermé SVG
            const eyeClosed = `
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
           class="lucide lucide-eye-closed">
        <path d="m15 18-.722-3.25"/>
        <path d="M2 8a10.645 10.645 0 0 0 20 0"/>
        <path d="m20 15-1.726-2.05"/>
        <path d="m4 15 1.726-2.05"/>
        <path d="m9 18 .722-3.25"/>
      </svg>`;

            // œil ouvert SVG
            const eyeOpen = `
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
           class="lucide lucide-eye">
        <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"></path>
        <circle cx="12" cy="12" r="3"></circle>
      </svg>`;

            if (input.type === 'password') {
                input.type = 'text';
                icon.innerHTML = eyeClosed;
            } else {
                input.type = 'password';
                icon.innerHTML = eyeOpen;
            }
        }
    </script>
{% endblock %}
