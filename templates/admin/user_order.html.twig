{% set productOrders = field.value %}
{% set order = productOrders|first ? productOrders|first.order : null %}

{% set pickupDays = { 2: 'Mardi', 5: 'Vendredi' } %}
{% set unitLabels = { 'PIECE': 'Pièce', 'BUNDLE': 'Botte', 'BUNCH': 'Bouquet', 'LITER': 'Litre', 'KG': 'Kilo' } %}

{% set grandTotal = 0 %}
{% for item in productOrders %}
    {% set grandTotal = grandTotal + (item.unitPrice / 100 * item.quantity) %}
{% endfor %}

<style>
    .order-detail {
        --order-accent: var(--button-primary-bg, #0d6efd);
    }

    /* Bloc résumé façon carte, avec filet primaire à gauche */
    .order-detail .order-summary {
        position: relative;
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 1.5rem;
        padding: 1.4rem 1.6rem 1.4rem 1.8rem;
        margin-bottom: 1.75rem;
        background: var(--bs-body-bg, #fff);
        border: 1px solid var(--bs-border-color, #e4e7e1);
        border-radius: 14px;
        box-shadow: 0 1px 2px rgba(0, 0, 0, .05);
        overflow: hidden;
    }

    .order-detail .order-summary::before {
        content: "";
        position: absolute;
        inset-block: 0;
        inset-inline-start: 0;
        inline-size: 4px;
        background: var(--order-accent);
    }

    .order-detail .order-summary-info {
        display: grid;
        grid-template-columns: repeat(2, minmax(170px, auto));
        gap: 1rem 2.5rem;
    }

    .order-detail .order-tile {
        display: flex;
        flex-direction: column;
        gap: .2rem;
    }

    .order-detail .order-tile-label {
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .04em;
        font-weight: 600;
        color: var(--bs-secondary-color, #6c757d);
    }

    .order-detail .order-tile-value {
        font-size: .98rem;
        font-weight: 600;
        color: var(--bs-body-color);
    }

    .order-detail .order-badge {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        padding: .25rem .7rem;
        border-radius: 999px;
        font-size: .8rem;
        font-weight: 600;
    }

    .order-detail .order-badge-pending { background: #fff3cd; color: #8a6100; }
    .order-detail .order-badge-done    { background: #d1e7dd; color: #0f5132; }
    .order-detail .order-badge-pickup  { background: rgba(13, 110, 253, .12); color: var(--order-accent); }

    .order-detail .order-summary-total { text-align: right; }

    .order-detail .order-summary-total .total-label {
        display: block;
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .04em;
        font-weight: 600;
        color: var(--bs-secondary-color, #6c757d);
    }

    .order-detail .order-summary-total .total-amount {
        font-size: 1.9rem;
        font-weight: 700;
        line-height: 1.1;
        color: var(--order-accent);
    }

    /* Tableau des lignes */
    .order-detail .order-table thead th {
        background: var(--order-accent);
        border-color: var(--order-accent);
        color: #fff;
        font-weight: 600;
    }

    .order-detail .order-table th,
    .order-detail .order-table td {
        vertical-align: middle;
    }

    .order-detail .num {
        text-align: right;
        font-variant-numeric: tabular-nums;
    }

    .order-detail .order-variant-badge {
        display: inline-block;
        margin-inline-start: .4rem;
        padding: .1rem .5rem;
        border-radius: 999px;
        background: rgba(13, 110, 253, .1);
        color: var(--order-accent);
        font-size: .78rem;
        font-weight: 600;
    }

    .order-detail .order-unit {
        color: var(--bs-secondary-color, #6c757d);
        font-size: .85rem;
    }

    .order-detail .order-total-row td {
        background: rgba(13, 110, 253, .06);
        border-top: 2px solid var(--order-accent);
        font-size: 1.02rem;
        font-weight: 700;
    }
</style>

<div class="order-detail">
    {% if order %}
        <div class="order-summary">
            <div class="order-summary-info">
                <div class="order-tile">
                    <span class="order-tile-label">Date</span>
                    <span class="order-tile-value">{{ order.createdAt|date('d/m/Y H:i') }}</span>
                </div>
                <div class="order-tile">
                    <span class="order-tile-label">Client</span>
                    <span class="order-tile-value">{{ order.user.firstName }} {{ order.user.lastName }}</span>
                </div>
                <div class="order-tile">
                    <span class="order-tile-label">Statut</span>
                    {% if order.done %}
                        <span class="order-badge order-badge-done">Traitée</span>
                    {% else %}
                        <span class="order-badge order-badge-pending">En attente</span>
                    {% endif %}
                </div>
                <div class="order-tile">
                    <span class="order-tile-label">Retrait</span>
                    <span class="order-badge order-badge-pickup">{{ pickupDays[order.pickupDay] ?? order.pickupDay }}</span>
                </div>
            </div>

            <div class="order-summary-total">
                <span class="total-label">Total</span>
                <span class="total-amount">{{ grandTotal|number_format(2, ',', ' ') }} €</span>
            </div>
        </div>
    {% endif %}

    {% if productOrders is not empty %}
        <div class="table-responsive">
            <table class="table table-hover align-middle order-table">
                <thead>
                <tr>
                    <th scope="col">Produit</th>
                    <th scope="col" class="num">Quantité</th>
                    <th scope="col" class="num">Prix unitaire (€)</th>
                    <th scope="col" class="num">Total ligne (€)</th>
                </tr>
                </thead>
                <tbody>
                {% for item in productOrders %}
                    {% set unit = item.unitPrice / 100 %}
                    {% set lineTotal = unit * item.quantity %}
                    <tr>
                        <td>
                            {{ item.product.name }}
                            {% if item.productVariant %}<span class="order-variant-badge">{{ item.productVariant.label }}</span>{% endif %}
                        </td>
                        <td class="num">
                            {{ item.quantity }}
                            {% if item.product.unit %}<span class="order-unit">({{ unitLabels[item.product.unit.value] ?? item.product.unit.value }})</span>{% endif %}
                        </td>
                        <td class="num">{{ unit|number_format(2, ',', ' ') }}</td>
                        <td class="num">{{ lineTotal|number_format(2, ',', ' ') }}</td>
                    </tr>
                {% endfor %}
                </tbody>
                <tfoot>
                <tr class="order-total-row">
                    <td colspan="3" class="text-end">Total</td>
                    <td class="num">{{ grandTotal|number_format(2, ',', ' ') }} €</td>
                </tr>
                </tfoot>
            </table>
        </div>
    {% else %}
        <p class="text-muted fst-italic">Aucun produit commandé</p>
    {% endif %}
</div>
